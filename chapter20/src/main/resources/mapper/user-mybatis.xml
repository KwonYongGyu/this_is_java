<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.mjc813.chapter20.usercrud.IUserMybatis">
    <insert id="insertData" parameterType="UserDto">
        INSERT INTO user_tbl (
            name
            ,password
            ,age
            ,email
        ) VALUES (
            #{name}
            , #{password}
            , #{age}
            , #{email}
        )
    </insert>

    <update id="updateData" parameterType="UserDto">
        UPDATE user_tbl SET
            name = #{name}
            , password = #{password}
            , age = #{age}
            , email = #{email}
        WHERE id = #{id}
    </update>
    <select id="selectAll" resultType="UserDto">
<!--        오름차순으로 DES는 내림차순-->
        SELECT * FROM User_tbl ORDER BY id ASC
    </select>

    <delete id="deleteData" parameterType="Integer">
        DELETE FROM user_tbl
        WHERE id = #{id}
    </delete>
</mapper>
